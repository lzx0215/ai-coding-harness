{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claude Review Output",
  "type": "object",
  "required": [
    "status",
    "run_id",
    "completed",
    "harness_version",
    "adapter_version",
    "prompt_version",
    "reviewer",
    "reviewer_model",
    "reviewer_model_version",
    "reviewer_cli_version",
    "output_file",
    "raw_log_file",
    "duration_seconds"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "findings",
        "failed",
        "timeout",
        "schema_invalid",
        "not_available"
      ]
    },
    "reason": {
      "type": "string",
      "enum": [
        "tool_missing",
        "auth_missing",
        "input_over_budget",
        "no_review_target",
        "unsupported_environment",
        "wrapper_failed_to_start"
      ]
    },
    "run_id": { "type": "string", "minLength": 1 },
    "completed": { "type": "boolean" },
    "harness_version": { "type": "string", "minLength": 1 },
    "adapter_version": { "type": "string", "minLength": 1 },
    "prompt_version": { "type": "string", "minLength": 1 },
    "reviewer": { "type": "string", "minLength": 1 },
    "reviewer_model": { "type": ["string", "null"], "minLength": 1 },
    "reviewer_model_version": { "type": ["string", "null"], "minLength": 1 },
    "reviewer_cli_version": { "type": ["string", "null"], "minLength": 1 },
    "reviewer_provenance": {
      "type": "object",
      "required": [
        "schema_version",
        "reviewer",
        "cli",
        "models",
        "primary_model",
        "unknowns"
      ],
      "properties": {
        "schema_version": { "type": "string", "const": "0.2.0" },
        "reviewer": { "type": "string", "minLength": 1 },
        "cli": {
          "type": "object",
          "required": ["name", "raw_version", "version"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "raw_version": { "type": ["string", "null"], "minLength": 1 },
            "version": { "type": ["string", "null"], "minLength": 1 }
          },
          "additionalProperties": false
        },
        "models": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "version", "source", "usage"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "version": { "type": ["string", "null"], "minLength": 1 },
              "source": { "type": "string", "enum": ["modelUsage", "metadata"] },
              "usage": {
                "type": "object",
                "required": ["input_tokens", "output_tokens"],
                "properties": {
                  "input_tokens": { "type": ["integer", "null"], "minimum": 0 },
                  "output_tokens": { "type": ["integer", "null"], "minimum": 0 }
                },
                "additionalProperties": false
              },
              "raw_usage": { "type": "object" }
            },
            "additionalProperties": false
          }
        },
        "primary_model": { "type": ["string", "null"], "minLength": 1 },
        "unknowns": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "model_name",
              "model_version",
              "cli_version",
              "primary_model",
              "token_usage"
            ]
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "models": { "maxItems": 0 }
            },
            "required": ["models"]
          },
          "then": {
            "properties": {
              "primary_model": { "const": null },
              "unknowns": {
                "allOf": [
                  { "contains": { "const": "model_name" } },
                  { "contains": { "const": "primary_model" } }
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "models": { "minItems": 1 }
            },
            "required": ["models"]
          },
          "then": {
            "properties": {
              "primary_model": { "type": "string", "minLength": 1 }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "output_file": { "type": "string", "minLength": 1 },
    "review_file": { "type": "string", "minLength": 1 },
    "raw_log_file": { "type": "string", "minLength": 1 },
    "exit_code": { "type": ["integer", "null"] },
    "duration_seconds": { "type": "number", "minimum": 0 },
    "summary": { "type": "string", "minLength": 1 },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "severity",
          "title",
          "evidence",
          "recommendation"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "title": { "type": "string", "minLength": 1 },
          "evidence": { "type": "string", "minLength": 1 },
          "recommendation": { "type": "string", "minLength": 1 },
          "file": { "type": "string", "minLength": 1 },
          "line": { "type": ["integer", "null"], "minimum": 1 }
        },
        "additionalProperties": false
      }
    },
    "tested": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "not_tested": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "residual_risks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "reviewer_provenance": {
            "properties": {
              "models": { "maxItems": 0 }
            },
            "required": ["models"]
          }
        },
        "required": ["reviewer_provenance"]
      },
      "then": {
        "properties": {
          "reviewer_model": { "const": null }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "not_available" }
        },
        "required": ["status"]
      },
      "then": {
        "required": ["reason"],
        "properties": {
          "completed": { "const": false }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "timeout",
              "failed",
              "schema_invalid"
            ]
          }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "completed": { "const": false }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "passed" }
        },
        "required": ["status"]
      },
      "then": {
        "required": [
          "review_file",
          "summary",
          "findings",
          "tested",
          "not_tested",
          "residual_risks"
        ],
        "properties": {
          "completed": { "const": true },
          "findings": { "maxItems": 0 }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": { "const": "findings" }
        },
        "required": ["status"]
      },
      "then": {
        "required": [
          "review_file",
          "summary",
          "findings",
          "tested",
          "not_tested",
          "residual_risks"
        ],
        "properties": {
          "completed": { "const": true },
          "findings": { "minItems": 1 }
        }
      }
    }
  ],
  "additionalProperties": false
}
